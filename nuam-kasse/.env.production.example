APP_NAME="Nuam Kasse"
APP_VERSION=0.6.1
APP_ENV=production
DEBUG=false
ENABLE_API_DOCS=false

POSTGRES_DB=nuam_kasse
POSTGRES_USER=nuam_app
POSTGRES_PASSWORD=replace-with-a-long-random-password

SESSION_COOKIE_NAME=nuam_kasse_session
SESSION_TTL_HOURS=168
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax

BACKEND_CORS_ORIGINS=
VITE_API_BASE_URL=/api/v1
VITE_APP_VERSION=0.6.1

# Existing external reverse proxy network on the VPS.
NUAM_KASSE_PROXY_NETWORK=proxy

CATEGORY_IMAGE_STORAGE_PATH=/app/uploads/category-images
CATEGORY_IMAGE_MAX_BYTES=5242880
